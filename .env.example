# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.

# Hugging Face token — required to download gated models (e.g. Qwen2.5-3B-Instruct).
# Obtain yours at https://huggingface.co/settings/tokens
# Leave blank to rely on a prior `huggingface-cli login` or public-only models.
HF_TOKEN=hf_your_token_here

# Local Fine-tuned Model Path (Overrides caching from huggingface)
# Set this to the absolute path of your merged_model directory after running fine-tuning
# LLM_MODEL_PATH=[path-to-project]/finetune/outputs/merged_model
